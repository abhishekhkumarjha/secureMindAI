# Development Environment Configuration Template
# Copy to .env and update with your values

# API Settings
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=true
LOG_LEVEL=DEBUG

# CORS Configuration (comma-separated for multiple origins)
# Include your Vercel frontend URL, e.g. https://secure-mind-xxx.vercel.app
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000

# Trusted Host header validation (comma-separated hostnames, or * for all)
ALLOWED_HOSTS=*

# Rate Limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# Dataset path overrides
AI_DATASET_DIR=./datasets
UNSW_NB15_CSV=./datasets/anomaly_detection/UNSW_NB15.csv
CICIDS2017_CSV=./datasets/threat_detection/cicids2017_cleaned.csv
USER_BEHAVIOR_CSV=./datasets/login_behavior/user_behavior.csv

# Model persistence overrides
AI_MODELS_DIR=./ai_models/trained_models
AI_EVAL_DIR=./ai_models/evaluation
AI_LOG_DIR=./ai_models/trained_models/logs

# Security (development - change for production!)
SECRET_KEY=change-me-in-production

# Deterministic behavior
AI_RANDOM_STATE=42
THREAT_RF_TOTAL_ESTIMATORS=200
THREAT_RF_STEP_ESTIMATORS=20
LOGIN_MAX_ROWS=50000

