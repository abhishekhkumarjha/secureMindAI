# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: FastAPI backend URL for production (Vercel, etc.).
# Example: https://securemind-api.onrender.com
# Leave empty for local dev when the Vite proxy forwards API calls to port 8000.
VITE_API_BASE_URL=""
